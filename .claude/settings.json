{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(secrets/unlocked/*)",
      "Read(secrets/secrets.json)",
      "Edit(secrets/unlocked/*)",
      "Edit(secrets/secrets.json)",
      "Write(secrets/unlocked/*)",
      "Write(secrets/secrets.json)",
      "Glob(secrets/unlocked/*)",
      "Glob(secrets/secrets.json)"
    ]
  }
}
